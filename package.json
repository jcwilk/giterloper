{
  "name": "giterloper",
  "version": "0.1.0",
  "description": "Git-based knowledge store manager",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gl": "node dist/lib/gl.js",
    "build": "tsc",
    "prepare": "npm run build",
    "test:unit": "npm run build && node --import tsx --test tests/unit/reconcile.test.ts tests/unit/paths.test.ts tests/unit/pinned.test.ts",
    "typecheck": "tsc --noEmit",
    "benchmark:embed": "node scripts/benchmark-embed.mjs"
  },
  "dependencies": {
    "@tobilu/qmd": "1.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7"
  }
}
