{
  "name": "giterloper",
  "version": "0.1.0",
  "description": "Git-based knowledge store manager",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "gl": "node .cursor/skills/gl/scripts/gl.mjs",
    "build": "tsc -p .cursor/skills/gl/tsconfig.build.json",
    "test:unit": "node --test --experimental-strip-types tests/unit/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "benchmark:embed": "node scripts/benchmark-embed.mjs"
  },
  "dependencies": {
    "@tobilu/qmd": "1.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.7"
  }
}
